.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.DS_Store
build/
*.gcode
*.3mf
*.fpp
*.egg-info/

# Keep local audio out of git by default. Commit only files you own and intend
# to ship with the box.
audio/**/*.mp3
audio/**/*.m4a
audio/**/*.wav
audio/**/*.flac
audio/**/*.ogg
audio/**/*.webm
audio/**/*.mp4
!audio/**/.gitkeep
!audio/**/README.md

# Runtime files generated by a real box.
config/control.json
config/device_state.json
config/guest_links.json
config/volume.json
*.zip
