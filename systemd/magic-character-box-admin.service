[Unit]
Description=Magic Character Box Admin UI
After=multi-user.target network.target sound.target
Wants=network.target sound.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/magic-character-box
Environment=XDG_RUNTIME_DIR=/run/user/1000
Environment=MAGIC_BOX_NFC=pn532
Environment=MAGIC_BOX_ADMIN_HOST=0.0.0.0
Environment=MAGIC_BOX_ADMIN_PORT=8080
Environment=MAGIC_BOX_AMP_SD_GPIO=16
Environment=MAGIC_BOX_DEFAULT_VOLUME=50
Environment=MAGIC_BOX_MAX_OUTPUT_VOLUME=75
Environment=MAGIC_BOX_AUDIO_BACKEND=subprocess
Environment="MAGIC_BOX_AUDIO_CMD=mpg123 -q -o alsa -a plughw:CARD=MAX98357A,DEV=0 --rate 48000 --stereo -e s16"
Environment=MAGIC_BOX_TRUST_PROXY_HEADERS=1
# Optional: set this after configuring Tailscale Serve or another HTTPS guest base URL.
# Environment=MAGIC_BOX_PREFERRED_GUEST_BASE_URL=https://your-box.your-tailnet.ts.net
ExecStart=/home/pi/magic-character-box/.venv/bin/python -m magic_box.admin --config /home/pi/magic-character-box/config/characters.json --nfc pn532
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
